{
  "name": "sitelen-layer-plugin",
  "version": "0.1.1",
  "description": "Site-owner display-layer plugin for toki pona pages (latin / sitelen-pona / sitelen-emoji)",
  "type": "module",
  "main": "./dist/sitelen-layer-plugin.umd.cjs",
  "module": "./dist/sitelen-layer-plugin.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/sitelen-layer-plugin.js",
      "require": "./dist/sitelen-layer-plugin.umd.cjs"
    },
    "./styles.css": "./dist/sitelen-layer-plugin.css"
  },
  "sideEffects": [
    "**/*.css"
  ],
  "files": [
    "dist",
    "vendor/sitelen-emoji-truth/default-stable.v1.json"
  ],
  "scripts": {
    "dev": "vite",
    "build": "vite build && tsc -p tsconfig.build.json",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "emoji:update": "node scripts/update-emoji-mapping.mjs",
    "test": "vitest",
    "test:run": "vitest run"
  },
  "keywords": [
    "toki-pona",
    "sitelen-pona",
    "sitelen-emoji",
    "plugin"
  ],
  "license": "MIT",
  "devDependencies": {
    "jsdom": "^26.1.0",
    "typescript": "^5.9.2",
    "vite": "^7.1.3",
    "vitest": "^3.2.4"
  }
}
